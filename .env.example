# .env.example
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------
# Auth service
# -----------------------------------------------------------------------
# HMAC-SHA256 signing key — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change_me_generate_a_secure_random_value

# Token TTL in seconds (default: 3600 = 1 hour)
TOKEN_TTL=3600

# Refresh token TTL in seconds (default: 86400 = 24 hours)
REFRESH_TTL=86400

# Maximum failed login attempts before account lock (default: 5)
MAX_LOGIN_ATTEMPTS=5

# -----------------------------------------------------------------------
# Frontend client
# -----------------------------------------------------------------------
REACT_APP_API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------
# Pipeline secrets (GitHub Actions — set via repository secrets, not here)
# -----------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# CONFLUENCE_URL=
# CONFLUENCE_TOKEN=
# CONFLUENCE_SPACE_KEY=
