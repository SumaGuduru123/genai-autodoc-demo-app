{
  "name": "genai-autodoc-demo-frontend",
  "version": "1.0.0",
  "description": "TypeScript frontend client for the Gen AI Auto-Doc demo app",
  "private": true,
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint frontend-client --ext .ts,.tsx --max-warnings 0",
    "test": "jest --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.5",
    "@typescript-eslint/eslint-plugin": "8.35.1",
    "@typescript-eslint/parser": "8.35.1",
    "eslint": "9.30.1",
    "jest": "29.7.0",
    "rimraf": "6.0.1",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
